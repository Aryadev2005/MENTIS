# ============================================================
# MENTIS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ─── AI / LLM APIs ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...
LANGSMITH_API_KEY=lsv2_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=mentis-prod

# ─── Auth (Clerk) ────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# ─── Payment (Razorpay) ──────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ─── Databases ───────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://mentis_user:mentis_dev_password@localhost:5432/mentis
POSTGRES_PASSWORD=mentis_dev_password
POSTGRES_SYNC_URL=postgresql://mentis_user:mentis_dev_password@localhost:5432/mentis

REDIS_URL=redis://:mentis_redis_dev@localhost:6379/0
REDIS_PASSWORD=mentis_redis_dev

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=mentis_qdrant_dev

SQLITE_PATH=./data/mentis_local.db

# ─── Security ────────────────────────────────────────────────
ENCRYPTION_KEY=generate-32-byte-hex-key-here
JWT_SECRET=generate-strong-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# ─── Application ─────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=true
LOG_LEVEL=info

# ─── Electron ────────────────────────────────────────────────
ELECTRON_IS_DEV=true
API_BASE_URL=http://localhost:8000
RENDERER_URL=http://localhost:5173
OVERLAY_URL=http://localhost:5174

# ─── Monitoring ──────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=mentis_grafana_dev
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=mentis-api

# ─── Feature Flags ───────────────────────────────────────────
ENABLE_OFFLINE_MODE=true
ENABLE_GROUP_MODE=true
ENABLE_SELF_LEARNING=true
OLLAMA_BASE_URL=http://localhost:11434

# ─── Razorpay Pricing (paise = INR × 100) ────────────────────
PRICE_STUDENT_MONTHLY=29900
PRICE_PRO_MONTHLY=79900
PRICE_OA_PASS=19900
